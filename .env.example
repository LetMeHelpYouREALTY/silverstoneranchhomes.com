# Get your v0 API key here: https://v0.dev/chat/settings/keys
V0_API_KEY="your_v0_api_key"

# RealScout (optional — defaults are baked into lib/realscout/config.ts)
# REALSCOUT_AGENT_ENCODED_ID=QWdlbnQtMjI1MDUw
# Paste the content value from GSC → Settings → Ownership verification → HTML tag
NEXT_PUBLIC_GSC_VERIFICATION=

# Google Analytics (already used in lib/analytics.ts)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
